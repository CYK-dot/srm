{#- srm_layout_generate.jinja2 - 单一模板文件 #}
{% if output_file == 'h' %}
/*
 * {{ output_file }} - Auto-generated SRM layout header
 * Generated at: {{ timestamp }}
 *
 * 此文件由 python 脚本生成，包含项目特定的宏定义。
 * 通用函数声明在 srm.h 中，由 srm 工具链持有。
 */
#ifndef SRM_LAYOUT_H
#define SRM_LAYOUT_H

#include <stdint.h>

/* ========================== Type Enumerations ========================== */
typedef enum {
{%- for type in type_enums %}
    SRM_TYPE_{{ type.c_name }} = {{ type.code }},
{%- endfor %}
} srm_type_t;

/* ========================== Storage IDs and Sizes ========================== */
{%- for storage in storages %}
#define SRM_STORAGE_{{ storage.c_name }}_ID   {{ storage.id }}
#define SRM_STORAGE_{{ storage.c_name }}_SIZE {{ storage.size }}
{%- endfor %}

/* ========================== Item IDs and Types ========================== */
{%- for item in items %}
#define SRM_ITEM_{{ item.c_name }}_ID   {{ item.id }}
#define SRM_ITEM_{{ item.c_name }}_TYPE {{ item.type_num }}
{%- endfor %}

/* ========================== Readonly Item Arrays ========================== */
{%- for item in readonly_items %}
extern const uint8_t SRM_ITEM_{{ item.c_name }}_VALUE[{{ item.length }}];
{%- endfor %}

#endif /* SRM_LAYOUT_H */

{% elif output_file == 'c' %}
/*
 * {{ output_file }} - Auto-generated SRM layout lookup implementation
 * Generated at: {{ timestamp }}
 */
#include "srm.h"
#include "srm_layout.h"
#include <stddef.h>

/* ========================== Readonly Item Arrays ========================== */
{%- for item in readonly_items %}
const uint8_t SRM_ITEM_{{ item.c_name }}_VALUE[{{ item.length }}] = {
{%- if item.readonly_type == 'string_value' %}
    {{ item.value_bytes }}
{%- elif item.readonly_type == 'file_value' %}
    {{ item.value_bytes }}
{%- endif %}
};
{%- endfor %}

/* ========================== srm_get_offset ========================== */
uint16_t srm_get_offset(uint16_t storage_id, uint16_t item_id)
{
    switch (storage_id) {
{%- for storage in storages %}
        case SRM_STORAGE_{{ storage.c_name }}_ID:  /* {{ storage.name }} (ID={{ storage.id }}) */
            switch (item_id) {
{%- for entry in layout_entries if entry.storage_id == storage.id %}
                case SRM_ITEM_{{ entry.item_c_name }}_ID: return {{ entry.offset }};  /* {{ entry.item_name }} */
{%- endfor %}
                default: return 0xFFFF;
            }
{%- endfor %}
        default: return 0xFFFF;
    }
}

/* ========================== srm_get_storage_size ========================== */
uint16_t srm_get_storage_size(uint16_t storage_id)
{
    switch (storage_id) {
{%- for storage in storages %}
        case SRM_STORAGE_{{ storage.c_name }}_ID: return SRM_STORAGE_{{ storage.c_name }}_SIZE;  /* {{ storage.name }} */
{%- endfor %}
        default: return 0;
    }
}

/* ========================== srm_get_item_size ========================== */
uint16_t srm_get_item_size(uint16_t item_id)
{
    switch (item_id) {
{%- for item in items %}
        case SRM_ITEM_{{ item.c_name }}_ID: return {{ item.length }};  /* {{ item.name }} */
{%- endfor %}
        default: return 0;
    }
}

/* ========================== srm_get_readonly_item ========================== */
const uint8_t *srm_get_readonly_item(uint16_t storage_id, uint16_t item_id)
{
    switch (storage_id) {
{%- for rs in readonly_storages %}
        case SRM_STORAGE_{{ rs.c_name }}_ID:  /* {{ rs.name }} (readonly) */
            switch (item_id) {
{%- for entry in layout_entries if entry.storage_id == rs.id %}
                case SRM_ITEM_{{ entry.item_c_name }}_ID: return &SRM_ITEM_{{ entry.item_c_name }}_VALUE[0];  /* {{ entry.item_name }} */
{%- endfor %}
                default: return NULL;
            }
{%- endfor %}
        default: return NULL;
    }
}

/* ========================== srm_get_readonly_storage ========================== */
const uint8_t *srm_get_readonly_storage(uint16_t storage_id)
{
    switch (storage_id) {
{%- for rs in readonly_storages %}
        case SRM_STORAGE_{{ rs.c_name }}_ID: return SRM_ITEM_{{ rs.first_item_c_name }}_VALUE;  /* {{ rs.name }} */
{%- endfor %}
        default: return NULL;
    }
}
{% endif %}
