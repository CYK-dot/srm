#ifndef SRM_LAYOUT_H
#define SRM_LAYOUT_H

#include <stdint.h>

/**
 * @defgroup srm_types SRM Type Enumerations
 * @{
 */
typedef enum {
{%- for type in type_enums %}
    SRM_TYPE_{{ type.c_name }} = {{ type.code }}, /**< {{ type.c_name }} type */
{%- endfor %}
} srm_type_t;
/** @} */

/**
 * @defgroup srm_storages SRM Storage IDs and Sizes
 * @{
 */
{%- for storage in storages %}
{{ render_comments(storage.comments) }}
#define SRM_STORAGE_{{ storage.c_name }}_ID   {{ storage.id }}   /**< Storage ID for {{ storage.name }} */
#define SRM_STORAGE_{{ storage.c_name }}_SIZE {{ storage.size }} /**< Storage size in bytes for {{ storage.name }} */
{%- endfor %}
/** @} */

/**
 * @defgroup srm_items SRM Item IDs and Types
 * @{
 */
{%- for item in items %}
{{ render_comments(item.comments) }}
#define SRM_ITEM_{{ item.c_name }}_ID   {{ item.id }}   /**< Item ID for {{ item.name }} */
#define SRM_ITEM_{{ item.c_name }}_TYPE {{ item.type_num }} /**< Item type code for {{ item.name }} */
{%- endfor %}
/** @} */

/**
 * @defgroup srm_readonly SRM Readonly Storage Arrays
 * @{
 */
{%- for rs in readonly_storages %}
extern const uint8_t g_srm_{{ rs.c_lower_name }}_value[{{ rs.total_size }}]; /**< Readonly storage for {{ rs.name }} */
{%- for item in rs.storage_items %}
#define SRM_ITEM_{{ item.item_c_name }}_OFFSET {{ item.offset }} /**< Offset of {{ item.item_name }} in {{ rs.name }} */
#define SRM_ITEM_{{ item.item_c_name }}_SIZE   {{ item.length }} /**< Size of {{ item.item_name }} */
{%- endfor %}
{%- endfor %}
/** @} */

#endif /* SRM_LAYOUT_H */

