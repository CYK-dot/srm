#include <stddef.h>

/**
 * @defgroup srm_readonly_arrays SRM Readonly Storage Arrays
 * @{
 */
{%- for rs in readonly_storages %}
const uint8_t g_srm_{{ rs.c_lower_name }}_value[{{ rs.total_size }}] = {
    {{ rs.merged_bytes }}
};
{%- endfor %}
/** @} */

/**
 * @brief Get the byte offset of an item within a storage.
 *
 * @param storage_id  Storage ID (SRM_STORAGE_*_ID)
 * @param item_id     Item ID (SRM_ITEM_*_ID)
 * @return Byte offset, or 0xFFFF if not found
 */
uint16_t srm_get_offset(uint16_t storage_id, uint16_t item_id)
{
    switch (storage_id) {
{%- for storage in storages %}
        case SRM_STORAGE_{{ storage.c_name }}_ID:  /* {{ storage.name }} (ID={{ storage.id }}) */
            switch (item_id) {
{%- for entry in layout_entries if entry.storage_id == storage.id %}
                case SRM_ITEM_{{ entry.item_c_name }}_ID: return {{ entry.offset }};  /* {{ entry.item_name }} */
{%- endfor %}
                default: return 0xFFFF;
            }
{%- endfor %}
        default: return 0xFFFF;
    }
}

/**
 * @brief Get the size of a storage in bytes.
 *
 * @param storage_id  Storage ID (SRM_STORAGE_*_ID)
 * @return Storage size in bytes, or 0 if not found
 */
uint16_t srm_get_storage_size(uint16_t storage_id)
{
    switch (storage_id) {
{%- for storage in storages %}
        case SRM_STORAGE_{{ storage.c_name }}_ID: return SRM_STORAGE_{{ storage.c_name }}_SIZE;  /* {{ storage.name }} */
{%- endfor %}
        default: return 0;
    }
}

/**
 * @brief Get the size of an item in bytes.
 *
 * @param item_id  Item ID (SRM_ITEM_*_ID)
 * @return Item size in bytes, or 0 if not found
 */
uint16_t srm_get_item_size(uint16_t item_id)
{
    switch (item_id) {
{%- for item in items %}
        case SRM_ITEM_{{ item.c_name }}_ID: return {{ item.length }};  /* {{ item.name }} */
{%- endfor %}
        default: return 0;
    }
}

/**
 * @brief Get a pointer to a readonly item's data.
 *
 * Items are accessed via offset within a contiguous storage array.
 *
 * @param storage_id  Storage ID (SRM_STORAGE_*_ID)
 * @param item_id     Item ID (SRM_ITEM_*_ID)
 * @return Pointer to item data, or NULL if not found
 */
const uint8_t *srm_get_readonly_item(uint16_t storage_id, uint16_t item_id)
{
{%- if readonly_storages %}
    switch (storage_id) {
{%- for rs in readonly_storages %}
        case SRM_STORAGE_{{ rs.c_name }}_ID:  /* {{ rs.name }} (readonly) */
            switch (item_id) {
{%- for item in rs.storage_items %}
                case SRM_ITEM_{{ item.item_c_name }}_ID: return &g_srm_{{ rs.c_lower_name }}_value[{{ item.offset }}];  /* {{ item.item_name }} */
{%- endfor %}
                default: return NULL;
            }
{%- endfor %}
        default: return NULL;
    }
{%- else %}
    (void)storage_id;
    (void)item_id;
    return NULL;
{%- endif %}
}

/**
 * @brief Get a pointer to the start of a readonly storage.
 *
 * @param storage_id  Storage ID (SRM_STORAGE_*_ID)
 * @return Pointer to storage start, or NULL if not found
 */
const uint8_t *srm_get_readonly_storage(uint16_t storage_id)
{
{%- if readonly_storages %}
    switch (storage_id) {
{%- for rs in readonly_storages %}
        case SRM_STORAGE_{{ rs.c_name }}_ID: return g_srm_{{ rs.c_lower_name }}_value;  /* {{ rs.name }} */
{%- endfor %}
        default: return NULL;
    }
{%- else %}
    (void)storage_id;
    return NULL;
{%- endif %}
}
